// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "cli_default_open_behavior": "new_window",
  "git": {
    "inline_blame": {
      "enabled": true
    }
  },
  "agent_servers": {
    "gemini": {
      "type": "registry"
    }
  },
  "diff_view_style": "split",
  "title_bar": {
    "show_menus": false,
    "show_branch_icon": true
  },
  "theme": "VSCode Dark Modern",

  "diagnostics": {
    "include_warnings": true
  },
  "show_edit_predictions": false,

  // START Pannels
  "calls": {
    "mute_on_join": true,
    "share_on_join": false
  },
  "collaboration_panel": {
    "default_width": 360,
    "dock": "right"
  },
  "git_panel": {
    "dock": "left",
    "default_width": 360
  },
  "outline_panel": {
    "dock": "left",
    "default_width": 360
  },
  "notification_panel": {
    "default_width": 360
  },
  "project_panel": {
    "default_width": 360,
    "dock": "right"
  },
  "agent": {
    "dock": "right",
    "default_profile": "write",
    "default_width": 360,
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6"
    }
  },
  // END Pannels

  "hide_mouse": "never",
  "completions": {
    "words": "enabled"
  },

  "buffer_font_features": { "calt": false }, // ligature
  "terminal": {
    
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
    "show_diagnostics": "all"
  },
  "preview_tabs": {
    "enabled": false
  },
  // "seed_search_query_from_cursor": "selection",
  "vim_mode": true,

  // for the popup whenever move / edit
  "auto_signature_help": false,
  "show_signature_help_after_edits": false,

  "vim": {
    "use_smartcase_find": true,
    "use_system_clipboard": "never",
    "toggle_relative_line_numbers": true
  },
  "use_smartcase_search": true,
  "relative_line_numbers": "enabled",
  "vertical_scroll_margin": 0,
  "format_on_save": "off",
  "tab_size": 2,
  "lsp": {
    "rust-analyzer": {
      "binary": {
        "path_lookup": true,
        "path": "/Users/yohanesbandung/.cargo/bin/rust-analyzer",
        "arguments": []
      }
    },
    "dart": {
      "binary": {
        "path": "/opt/homebrew/bin/fvm",
        "arguments": ["dart", "language-server", "--protocol=lsp"]
      }
    },
    "jdtls": {
      "settings": {
        "java_home": "/Users/ybbond/.tool_binaries/zulu25.30.17-ca-jdk25.0.1-macosx_aarch64/"
      }
    }
  },
  "languages": {
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "TSX": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    }
    // "JavaScript": {
    //   "prettier": { "allowed": false },
